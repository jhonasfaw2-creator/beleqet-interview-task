# =============================================================================
# Beleqet Backend — Local Environment Variables
# =============================================================================

NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# Local connection fallback (if you ever run the app outside Docker)
DATABASE_URL=postgresql://beleqet_user:your_password@localhost:5432/beleqet_db
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# Security
# Generated with: openssl rand -hex 64
JWT_ACCESS_SECRET=docker_default_secret_please_change_in_production_abcdef123456
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# AI Integration
OPENAI_API_KEY=dummy_key_for_testing
OPENAI_MODEL=gpt-4o-mini

# Telegram Bot Integration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=-1001234567890

# Chapa Payment Gateway Integration
CHAPA_SECRET_KEY=CHASECK_TEST-mocksecretkey123456789
CHAPA_PUBLIC_KEY=CHAPUBK_TEST-mockpublickey123456789
CHAPA_WEBHOOK_SECRET=your_webhook_secret
CHAPA_CALLBACK_URL=http://localhost:4000/api/v1/escrow/callback
CHAPA_RETURN_URL=http://localhost:3000/freelance/payment-success

# Storage
AWS_S3_BUCKET=beleqet-uploads
AWS_ACCESS_KEY_ID=mock_access_key_id
AWS_SECRET_ACCESS_KEY=mock_secret_access_key
AWS_REGION=us-east-1

# Email Service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@beleqet.com
SMTP_PASS=your_smtp_password
EMAIL_FROM=Beleqet <noreply@beleqet.com>

# Background Task Dashboard (Bull Board)
BULL_BOARD_USERNAME=admin
BULL_BOARD_PASSWORD=admin